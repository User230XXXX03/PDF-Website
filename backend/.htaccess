# Enable Rewrite Engine
RewriteEngine On

# Rewrite API routes
# Example: /api/auth/login -> /api/auth.php?action=login
RewriteRule ^api/auth/(.+)$ api/auth.php?action=$1 [QSA,L]
RewriteRule ^api/templates/([0-9]+)$ api/templates.php?id=$1 [QSA,L]
RewriteRule ^api/templates$ api/templates.php [QSA,L]
RewriteRule ^api/batches/([0-9]+)$ api/batches.php?id=$1 [QSA,L]
RewriteRule ^api/batches$ api/batches.php [QSA,L]
RewriteRule ^api/pdf/(.+)$ api/pdf.php?action=$1 [QSA,L]
RewriteRule ^api/email/(.+)$ api/email.php?action=$1 [QSA,L]
RewriteRule ^api/dashboard$ api/dashboard.php [QSA,L]
RewriteRule ^api/logs$ api/logs.php [QSA,L]

# Deny access to sensitive files
<FilesMatch "\.(htaccess|htpasswd|ini|log|sh|sql)$">
    Order Allow,Deny
    Deny from all
</FilesMatch>

